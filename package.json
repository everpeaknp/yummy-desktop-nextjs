{
  "name": "yummy-web",
  "version": "0.1.5",
  "private": true,
  "homepage": "https://www.yummyever.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/everpeaknp/yummy-desktop-nextjs.git"
  },
  "main": "main.js",
  "scripts": {
    "predev": "node scripts/clean-next.js",
    "dev": "next dev",
    "prebuild": "node scripts/clean-next.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:3000 && cross-env NODE_ENV=development ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "electron:build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "electron:build:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "electron:build:win:portable": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "electron:build:all": "npm run build && electron-builder -mwl"
  },
  "build": {
    "appId": "com.yummy.pos",
    "productName": "Yummy POS",
    "executableName": "YummyPOS",
    "directories": {
      "output": "dist",
      "buildResources": "electron-resources"
    },
    "forceCodeSigning": false,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "asar": true,
    "icon": "electron-resources/icon.ico",
    "files": [
      "main.js",
      "electron-auth-persist.js",
      "preload.js",
      "electron-resources/icon.ico",
      "electron-resources/icon.png",
      "electron-resources/icon-256.png",
      "!node_modules",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/debug/**/*",
      "node_modules/sax/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/universalify/**/*",
      "node_modules/argparse/**/*",
      "node_modules/ms/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "everpeaknp",
      "repo": "yummy-desktop-nextjs"
    },
    "win": {
      "icon": "electron-resources/icon.ico",
      "target": [
        "portable",
        "nsis"
      ],
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "afterPack": "scripts/afterPack-set-win-icon.js",
    "portable": {
      "artifactName": "Yummy.POS.Portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron-resources/icon.ico",
      "uninstallerIcon": "electron-resources/icon.ico",
      "installerHeaderIcon": "electron-resources/icon.ico",
      "artifactName": "Yummy.POS.Setup.${version}.${ext}",
      "uninstallUrlHelp": "https://www.yummyever.com/faq",
      "uninstallUrlInfoAbout": "https://www.yummyever.com/help",
      "uninstallUrlUpdateInfo": "https://www.yummyever.com/features"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        "AppImage",
        "snap"
      ]
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-query": "^5.59.0",
    "@types/uuid": "^11.0.0",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "firebase": "^12.9.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jsqr": "^1.4.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.453.0",
    "next": "14.2.15",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-day-picker": "^9.13.2",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "rcedit": "^4.0.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "wait-on": "^9.0.10"
  }
}
